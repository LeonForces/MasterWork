POSTGRES_DB=video_analytics
POSTGRES_USER=video_app
POSTGRES_PASSWORD=video_app_password
POSTGRES_HOST_PORT=55432
DATABASE_URL=postgresql+psycopg2://video_app:video_app_password@postgres:5432/video_analytics

RABBITMQ_USER=video_app
RABBITMQ_PASSWORD=video_app_password
RABBITMQ_ERLANG_COOKIE=video_analytics_rabbit_cookie_change_me_2026
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_EXCHANGE=events.topic.v1
RABBITMQ_QUEUE=integration.webhook.v1
RABBITMQ_DLQ=integration.webhook.v1.dlq

JWT_SECRET_KEY=change_this_secret_key_change_this_secret_key_1234
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin12345

WEBHOOK_TARGET_URL=http://webhook-mock:8090/webhook/events
API_BASE_URL=http://api:8000
UI_API_BASE_URL=http://localhost:8000

METRICS_PORT_ANALYTICS=9101
METRICS_PORT_INTEGRATION=9102

CORS_ORIGINS=http://localhost:4173,http://ui:4173

DETECTOR_MODEL=/app/models/best.pt
DETECTOR_CLASSES=drone,bird
DETECTOR_CONFIDENCE=0.25
USE_MOCK_DETECTOR=false

DEMO_DRONE_ENABLED=true
DEMO_DRONE_CAMERA_NAME=demo-drone-video
DEMO_DRONE_SOURCE=/app/videos/V_DRONE_009.mp4
DEMO_DRONE_RESOLUTION=640x512
DEMO_DRONE_FPS_TARGET=10
DEMO_DRONE_EXCLUSIVE=true
